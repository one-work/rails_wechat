<%= turbo_stream.update 'weui-tab__panel' do %>
  <div
    data-controller="mini-program"
    data-mini-program-direct-value="true"
    data-mini-program-launch-value="true"
    data-mini-program-url-value="/pages/login/index"
    data-mini-program-data-value="<%=
      {
        url: url_for(controller: 'wechat/program_users', action: 'create', only_path: false),
        state: state,
        auth_appid: Rails.configuration.x.appid.presence
      }.compact.to_json
    %>"
    class="has-column-centered"
    style="height: 100%"
  >
    <p style="color: darkgray">登录信息失效，等待授权...</p>
  </div>
<% end %>
