<td><strong class="text-success"><%= position %></strong></td>
<td>
  <% if model.is_a? Wechat::MenuRoot %>
    <strong><%= model.name %></strong>
    <span class="tag">默认</span>
  <% elsif model.is_a? Wechat::MenuRootApp %>
    <strong><%= model.name %></strong>
    <span class="tag">自定义</span>
  <% end %>
</td>
<td></td>
<td>
  <div data-show-target="item" class="visibility-hidden">
  <% if model.nil? %>
    <%= button_to({ controller: 'menu_root_apps', action: 'new' }, params: { 'menu_root_app[position]': position }, class: 'button is-small is-outlined is-link') do %>
      <%= svg_tag 'plus' %>
      <span><%= t('.menu_root_apps.new.title') %></span>
    <% end %>
  <% elsif model.is_a?(Wechat::MenuRootApp) %>
    <%= button_to({ controller: 'menu_root_apps', action: 'edit', id: model.id }, class: 'button is-small is-outlined is-link') do %>
      <%= svg_tag 'pencil' %>
      <span><%= t('.menu_root_apps.edit.title') %></span>
    <% end %>
    <%= button_to({ controller: 'menu_root_apps', action: 'destroy', id: model.id }, method: :delete, class: 'button is-small is-outlined is-danger') do %>
      <%= svg_tag 'trash' %>
      <span><%= t('.menu_root_apps.destroy.title') %></span>
    <% end %>
  <% else %>
    <%= button_to({ controller: 'menu_root_apps', action: 'new' }, params: { 'menu_root_app[position]': position }, class: 'button is-small is-outlined is-link') do %>
      <%= svg_tag 'plus' %>
      <span><%= t('.menu_root_apps.new.title') %></span>
    <% end %>
  <% end %>
  </div>
</td>
