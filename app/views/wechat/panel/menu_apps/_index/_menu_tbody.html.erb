<td>
  <span class="text-grey"><%= model.position %></span>
</td>
<td>
  <span style="width: 1em; display: inline-block"></span>
  <span><%= model.name %></span>
  <span class="tag"><%= model.type_i18n %></span>
</td>
<td>
  <p><%= model.value %></p>
  <p><%= model.mp_appid %></p>
  <p><%= model.mp_pagepath %></p>
</td>
<td>
  <% if menu.disabled %>
    <%= button_to({ controller: 'menu_disables', action: 'destroy', menu_id: model.id, id: menu_disable.id }, method: :delete, aria: { label: '添加' }, class: 'button is-small is-borderless') do %>
      <%= svg_tag 'xmark', class: 'icon is-small text-danger' %>
    <% end %>
  <% else %>
    <%= button_to({ controller: 'menu_disables', action: 'create', menu_id: model.id }, aria: { label: t('.destroy.title') }, class: 'button is-small is-borderless') do %>
      <%= svg_tag 'check', class: 'icon is-small text-success' %>
    <% end %>
  <% end %>
  <%= button_to({ controller: 'menu_apps', action: 'new', menu_id: model.id }, params: { 'menu_app[menu_position]': model.position }, class: 'button is-small is-link') do %>
    <%= svg_tag 'plus' %>
    <span class="ml-1"><%= t('.new.title') %></span>
  <% end %>
</td>