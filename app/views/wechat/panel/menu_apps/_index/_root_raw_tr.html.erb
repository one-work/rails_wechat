<tr data-depth="10" data-controller="tree show" data-tree-target="item" class="<%= 'background-white-ter' %>">
  <td colspan="3"></td>
  <td>
    <div data-show-target="item" class="visibility-hidden">
      <%= button_to({ controller: 'menu_root_apps', action: 'new' }, class: 'button is-small is-outlined is-link') do %>
        <%= svg_tag 'plus' %>
        <span><%= t('.menu_root_apps.new.title') %></span>
      <% end %>
    </div>
  </td>
</tr>
<% Wechat::MenuRootApp.where(appid: @app.appid, menu_root_id: nil).each do |child| %>
  <%= render partial: 'root_tbody', layout: 'root_app_tr', locals: { model: child } %>
<% end %>
