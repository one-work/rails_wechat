<%=
  tr_tag(
    model,
    {
      href: url_for(controller: 'corp_users', agent_id: model.id),
      icon: 'building-user',
      title: t('.corp_users.index.title')
    },
    {
      href: url_for(controller: 'suite_receives', agent_id: model.id),
      icon: 'message',
      title: t('.suite_receives.index.title')
    },
    {
      action: url_for(action: 'edit_confirm', id: model.id),
      icon: 'file',
      title: t('.edit_confirm.title')
    },
    {
      action: url_for(action: 'info', id: model.id),
      icon: 'gear',
      title: t('.info.title')
    }
  ) { yield }
%>
