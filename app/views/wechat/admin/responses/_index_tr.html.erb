<%=
  tr_tag(
    model,
    {
      href: url_for(controller: 'extractors', response_id: model.id),
      icon: 'expand',
      title: t('.extractors.index.title')
    },
    {
      href: url_for(action: 'edit_reply', id: model.id),
      icon: 'pencil',
      title: t('.edit_reply.title')
    }
  ) { yield }
%>
